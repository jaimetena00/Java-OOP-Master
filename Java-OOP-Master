<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Java OOP Master - 1º DAW</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        .code-font { font-family: 'Fira Code', monospace; }
        .gap-input {
            background: #2d3748;
            border-bottom: 2px solid #4a5568;
            color: #ecc94b;
            padding: 0 4px;
            outline: none;
            transition: all 0.2s;
            min-width: 60px;
            display: inline-block;
        }
        .gap-input:focus { border-color: #ecc94b; background: #334155; }
        .fade-in { animation: fadeIn 0.5s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="min-h-screen text-slate-800">

    <div id="app" class="max-w-4xl mx-auto p-4 md:p-8">
        <!-- Header -->
        <header class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-indigo-700">Java OOP Master</h1>
                <p class="text-slate-500 italic">Formación Profesional - 1º DAW</p>
            </div>
            <div class="flex items-center gap-4">
                <div class="bg-white shadow-sm border px-4 py-2 rounded-xl flex items-center gap-2">
                    <span class="text-xs font-bold text-slate-400 uppercase">Nivel:</span>
                    <select id="difficulty-select" onchange="changeDifficulty(this.value)" class="bg-transparent font-semibold text-indigo-600 outline-none cursor-pointer">
                        <option value="Principiante">Principiante (Clases/Atributos)</option>
                        <option value="Intermedio">Intermedio (Constructores/Métodos)</option>
                        <option value="Avanzado">Avanzado (Herencia/Polimorfismo)</option>
                    </select>
                </div>
                <div class="bg-indigo-100 text-indigo-700 px-4 py-2 rounded-xl font-bold">
                    Puntos: <span id="score">0</span>
                </div>
            </div>
        </header>

        <main id="game-container" class="space-y-6">
            <!-- Loading State -->
            <div id="loading" class="hidden py-20 text-center">
                <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-indigo-500 border-t-transparent mb-4"></div>
                <p class="text-slate-500">Generando nuevo desafío con IA...</p>
            </div>

            <!-- Welcome View -->
            <div id="welcome-view" class="bg-white p-8 rounded-3xl shadow-xl border border-slate-100 text-center space-y-6">
                <div class="bg-indigo-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto text-4xl">☕</div>
                <h2 class="text-2xl font-bold">¿Listo para dominar la POO?</h2>
                <p class="text-slate-600 max-w-md mx-auto">Practica conceptos clave de Java como encapsulamiento, herencia y constructores rellenando los huecos en el código.</p>
                <button onclick="fetchNewExercise()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-3 rounded-2xl font-semibold shadow-lg transition-all active:scale-95">
                    Empezar Práctica
                </button>
            </div>

            <!-- Exercise View -->
            <div id="exercise-view" class="hidden space-y-6 fade-in">
                <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-100">
                    <h3 id="topic-tag" class="text-xs font-bold uppercase tracking-widest text-indigo-500 mb-2">TEMA</h3>
                    <p id="exercise-context" class="text-lg text-slate-700 leading-relaxed"></p>
                </div>

                <div class="relative bg-slate-900 rounded-3xl p-6 shadow-2xl overflow-x-auto">
                    <div class="absolute top-4 right-6 text-slate-500 text-xs font-mono uppercase">Java Code</div>
                    <pre id="code-block" class="code-font text-slate-300 leading-loose"></pre>
                </div>

                <div class="flex justify-between items-center pt-4">
                    <div id="feedback-message" class="text-sm font-medium"></div>
                    <div class="space-x-4">
                        <button onclick="checkAnswers()" id="check-btn" class="bg-emerald-500 hover:bg-emerald-600 text-white px-6 py-3 rounded-2xl font-semibold shadow-md transition-all">
                            Verificar Solución
                        </button>
                        <button onclick="fetchNewExercise()" id="next-btn" class="hidden bg-slate-200 hover:bg-slate-300 text-slate-700 px-6 py-3 rounded-2xl font-semibold transition-all">
                            Siguiente Ejercicio
                        </button>
                    </div>
                </div>
            </div>

            <div id="explanation-view" class="hidden bg-amber-50 border border-amber-200 p-6 rounded-3xl fade-in">
                <div class="flex gap-4">
                    <div class="text-2xl">💡</div>
                    <div>
                        <h4 class="font-bold text-amber-800 mb-1">Explicación del Profe:</h4>
                        <div id="explanation-text" class="text-amber-900 text-sm leading-relaxed"></div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        let currentDifficulty = "Principiante";
        let score = 0;
        let currentExercise = null;
        const apiKey = ""; // API Key automatizada por el sistema Canvas

        
        async function callGemini(prompt, isJson = true) {
            const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-3-flash-preview:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: prompt }] }],
                generationConfig: {
                    responseMimeType: isJson ? "application/json" : "text/plain"
                }
            };

            // Implementación de reintentos con backoff exponencial
            let delay = 1000;
            for (let i = 0; i < 3; i++) {
                try {
                    const response = await fetch(apiUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const result = await response.json();
                    return result.candidates?.[0]?.content?.parts?.[0]?.text;
                } catch (e) {
                    if (i === 2) throw e;
                    await new Promise(r => setTimeout(r, delay));
                    delay *= 2;
                }
            }
        }

        async function fetchNewExercise() {
            toggleUI('loading');
            hideExplanation();
            
            const prompt = `Actúa como un profesor experto en Java para alumnos de 1º DAW (Formación Profesional). 
            Genera un ejercicio interactivo de Programación Orientada a Objetos en Java para el nivel: ${currentDifficulty}.
            El ejercicio debe ser un código de Java con huecos marcados como {{GAP}}.
            
            Devuelve un JSON con este esquema:
            {
                "topic": "Un nombre corto del tema (ej: Constructores)",
                "context": "Una instrucción clara de qué debe hacer el alumno en este ejercicio.",
                "code": "El código Java con marcadores {{GAP}} donde el alumno debe escribir.",
                "answers": ["array con las palabras exactas que van en cada {{GAP}} en orden"],
                "hint": "Una pequeña pista por si se atasca."
            }
            
            Reglas: 
            - Si es Principiante: clases simples, atributos, modificadores de acceso.
            - Si es Intermedio: constructores (default y con parámetros), métodos getter/setter, uso de 'this'.
            - Si es Avanzado: herencia (extends), sobrescritura de métodos (@Override), palabra clave 'super', polimorfismo básico.`;

            try {
                const responseText = await callGemini(prompt);
                currentExercise = JSON.parse(responseText);
                renderExercise();
                toggleUI('exercise');
            } catch (error) {
                console.error(error);
                alert("Error al conectar con el servidor de ejercicios. Reintenta.");
                toggleUI('welcome');
            }
        }

        function renderExercise() {
            document.getElementById('topic-tag').innerText = currentExercise.topic;
            document.getElementById('exercise-context').innerText = currentExercise.context;
            
            const codeBlock = document.getElementById('code-block');
            let codeHtml = currentExercise.code
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");
            
            // Reemplazar {{GAP}} por inputs interactivos
            let gapIndex = 0;
            codeHtml = codeHtml.replace(/{{GAP}}/g, () => {
                const input = `<input type="text" class="gap-input" data-index="${gapIndex}" oninput="this.style.width = ((this.value.length + 1) * 8) + 'px'">`;
                gapIndex++;
                return input;
            });
            
            codeBlock.innerHTML = codeHtml;
            document.getElementById('feedback-message').innerText = "";
            document.getElementById('check-btn').classList.remove('hidden');
            document.getElementById('next-btn').classList.add('hidden');
        }


        async function checkAnswers() {
            const inputs = document.querySelectorAll('.gap-input');
            let allCorrect = true;
            let userAnswers = [];
            
            inputs.forEach((input, idx) => {
                const val = input.value.trim();
                userAnswers.push(val);
                if (val === currentExercise.answers[idx]) {
                    input.classList.add('text-emerald-400');
                    input.classList.remove('text-rose-400');
                } else {
                    allCorrect = false;
                    input.classList.add('text-rose-400');
                    input.classList.remove('text-emerald-400');
                }
            });

            if (allCorrect) {
                score += 10;
                document.getElementById('score').innerText = score;
                document.getElementById('feedback-message').innerHTML = `<span class="text-emerald-600 font-bold">¡Excelente! ¡Código compilado correctamente! +10 puntos</span>`;
                document.getElementById('check-btn').classList.add('hidden');
                document.getElementById('next-btn').classList.remove('hidden');
            } else {
                document.getElementById('feedback-message').innerHTML = `<span class="text-rose-600 font-bold">Hay errores en el código. Analizando...</span>`;
                explainError(userAnswers);
            }
        }

        async function explainError(userAnswers) {
            const prompt = `Un alumno de 1º DAW ha fallado un ejercicio de Java OOP.
            Ejercicio: ${currentExercise.code}
            Sus respuestas: ${userAnswers.join(', ')}
            Respuestas correctas: ${currentExercise.answers.join(', ')}
            Contexto: ${currentExercise.context}
            
            Explícale de forma muy sencilla, amable y pedagógica por qué se ha equivocado. 
            No le des solo la respuesta, explica el concepto detrás (ej: por qué se usa 'this', qué hace 'super', la diferencia entre 'private' y 'public', etc.). Máximo 3 líneas.`;

            const explanation = await callGemini(prompt, false);
            document.getElementById('explanation-text').innerText = explanation;
            document.getElementById('explanation-view').classList.remove('hidden');
        }


        function toggleUI(view) {
            document.getElementById('welcome-view').classList.add('hidden');
            document.getElementById('exercise-view').classList.add('hidden');
            document.getElementById('loading').classList.add('hidden');
            
            if(view === 'loading') document.getElementById('loading').classList.remove('hidden');
            if(view === 'exercise') document.getElementById('exercise-view').classList.remove('hidden');
            if(view === 'welcome') document.getElementById('welcome-view').classList.remove('hidden');
        }

        function hideExplanation() {
            document.getElementById('explanation-view').classList.add('hidden');
        }

        function changeDifficulty(val) {
            currentDifficulty = val;
            score = 0;
            document.getElementById('score').innerText = score;
            toggleUI('welcome');
        }

        window.onload = () => {
            console.log("Java OOP Master cargado.");
        };
    </script>
</body>
</html>
